{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "outDir": ".cache/tsconfig-node"
  },
  "//": "Only include the React-free map modules reused by Node scripts.",
  "include": ["vite.config.ts", "scripts/**/*.ts", "shared/maps/**/*.ts", "src/authoring/model.ts"]
}
