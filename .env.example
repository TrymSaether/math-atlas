# Server environment. Copy to `.env` and fill in real values for local dev.
# `.env` is gitignored; never commit secrets. Loaded in dev via
# `node --env-file-if-exists=.env` (see the npm scripts); in prod the values
# come from the Render dashboard.

# Postgres connection string (matches docker-compose.yml defaults).
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# Secret used by better-auth to sign sessions. Use a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Public origin of the app + API server. better-auth appends /api/auth.
# Local Google OAuth redirect URI:
#   http://localhost:8787/api/auth/callback/google
BETTER_AUTH_URL=http://localhost:8787

# Google OAuth client credentials for "Continue with Google".
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Port the server listens on.
PORT=8787
