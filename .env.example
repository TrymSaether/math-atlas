# Backend environment. Copy to `.env` and fill in real values for local dev.
# `.env` is gitignored; never commit secrets.

# Postgres connection string (matches docker-compose.yml defaults).
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# Secret used by better-auth to sign sessions. Use a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Public origin of the API server. better-auth appends /api/auth internally.
# Local Google OAuth redirect URI:
#   http://localhost:8787/api/auth/callback/google
BETTER_AUTH_URL=http://localhost:8787

# Google OAuth client credentials for "Continue with Google".
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Port the Hono API server listens on.
PORT=8787

# Origin of the SPA. Used as the default trusted origin in dev.
APP_URL=http://localhost:5173

# Production: comma-separated browser origins allowed to call the API (CORS +
# CSRF). Set this on the API host to your GitHub Pages origin, e.g.:
#   WEB_ORIGINS=https://trymsaether.github.io
# (Any localhost port is always allowed in code, so leave unset for local dev.)
# WEB_ORIGINS=

# --- Frontend build (Vite), NOT read by the server ---
# Absolute URL of the deployed API, baked into the SPA at build time. Leave
# unset for local dev (the Vite proxy handles /api). For the GitHub Pages build,
# set this in the deploy workflow, e.g. VITE_API_URL=https://your-api.onrender.com
# VITE_API_URL=
