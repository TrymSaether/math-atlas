            ]
          },
          "label": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "confidence": {
            "type": [
              "number",
              "string"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
