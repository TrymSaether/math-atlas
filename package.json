{
  "name": "math-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch --env-file-if-exists=.env server/index.ts",
    "start:server": "node server/index.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "atlas": "node scripts/atlas/cli.ts",
    "check:maps": "node scripts/build-maps.ts",
    "seed:maps": "node --env-file-if-exists=.env server/seed.ts",
    "build": "npm run check:maps && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome ci . && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@xyflow/react": "^12.11.1",
    "better-auth": "^1.6.19",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "katex": "^0.17.0",
    "lucide-react": "^1.22.0",
    "mafs": "^0.21.0",
    "mathjs": "^15.2.0",
    "mathlive": "^0.110.0",
    "motion": "^12.42.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
