{
  "name": "math-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "atlas": "scripts/atlas/bin.mjs"
  },
  "scripts": {
    "predev": "npm run build:maps",
    "dev": "vite",
    "atlas": "tsx scripts/atlas/cli.ts",
    "build:maps": "tsx scripts/build-maps.ts",
    "check:maps": "tsx scripts/build-maps.ts --check",
    "build": "npm run build:maps && tsc -b && vite build",
    "prepreview": "npm run build:maps",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{ts,js,mjs}\" \"*.{js,ts,json,html}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{ts,js,mjs}\" \"*.{js,ts,json,html}\" \"docs/**/*.md\"",
    "format:maps": "atlas format",
    "check": "npm run format:check && npm run lint && npm run build"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.16",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "mafs": "^0.21.0",
    "mathjs": "^15.2.0",
    "mathlive": "^0.110.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
