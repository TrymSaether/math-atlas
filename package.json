{
  "name": "math-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "atlas": "scripts/atlas/bin.mjs"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "start:server": "tsx server/index.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "npm run seed:maps",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:server": "tsc -p server/tsconfig.json",
    "atlas": "tsx scripts/atlas/cli.ts",
    "check:maps": "tsx scripts/build-maps.ts --check",
    "seed:maps": "tsx server/seed.ts",
    "build:app": "tsc -b && vite build",
    "build": "npm run check:maps && npm run build:app",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"server/**/*.ts\" \"scripts/**/*.{ts,js,mjs}\" \"*.{js,ts,json,html}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"server/**/*.ts\" \"scripts/**/*.{ts,js,mjs}\" \"*.{js,ts,json,html}\" \"docs/**/*.md\"",
    "format:maps": "atlas format",
    "check": "npm run format:check && npm run lint && npm run typecheck:server && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.17",
    "@xyflow/react": "^12.11.1",
    "better-auth": "^1.6.19",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "katex": "^0.17.0",
    "lucide-react": "^1.22.0",
    "mafs": "^0.21.0",
    "mathjs": "^15.2.0",
    "mathlive": "^0.110.0",
    "motion": "^12.42.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
